// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum EventStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum BetStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  twoFactorKey String?  // Chave do 2FA
  balance      Decimal  @default(0.0) @db.Decimal(10, 2)
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bets         Bet[]
  transactions Transaction[]
}

model Event {
  id          String      @id @default(uuid())
  sportType   String      // Ex: "SOCCER", "TENNIS"
  homeTeam    String
  awayTeam    String
  startTime   DateTime
  status      EventStatus @default(SCHEDULED)
  providerId  String?     // ID do evento no provedor (Sportradar)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  odds        Odd[]
}

model Odd {
  id        String   @id @default(uuid())
  eventId   String
  type      String   // Ex: "1X2", "OVER_UNDER_2.5"
  selection String   // Ex: "HOME", "DRAW", "AWAY"
  value     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id])
  bets      Bet[]
}

model Bet {
  id        String    @id @default(uuid())
  userId    String
  oddId     String
  amount    Decimal   @db.Decimal(10, 2)
  potential Decimal   @db.Decimal(10, 2) // Retorno possível
  status    BetStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  odd       Odd       @relation(fields: [oddId], references: [id])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Decimal  @db.Decimal(10, 2)
  type      String   // "DEPOSIT", "WITHDRAWAL"
  gateway   String   // "PIX", "STRIPE"
  status    String   // "PENDING", "COMPLETED", "FAILED"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
